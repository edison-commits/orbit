{
  "expo": {
    "name": "Orbit",
    "slug": "orbit",
    "version": "1.0.0",
    "scheme": "orbit",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#7C5CFC"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.orbit.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Orbit uses the camera to take profile photos of your contacts.",
        "NSPhotoLibraryUsageDescription": "Orbit accesses your photo library to add profile photos of your contacts.",
        "NSUserNotificationsUsageDescription": "Orbit sends reminders when it's time to check in with someone."
      }
    },
    "android": {
      "package": "com.orbit.app",
      "adaptiveIcon": {
        "backgroundColor": "#7C5CFC",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#7C5CFC"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Orbit accesses your photo library to add profile photos of your contacts.",
          "cameraPermission": "Orbit uses the camera to take profile photos of your contacts."
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "cooprCoep": true
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4a652d2b-8179-421d-882b-b881b43423ec"
      }
    },
    "owner": "edisonclaw"
  }
}
